# .gitignore
# Environment files
.env
.env.local
.env.*.local
.env.development
.env.staging
.env.production

# But keep example files
!.env.example
!.env.docker

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/

# Database migrations
migrations/master/versions/*.py
!migrations/master/versions/__init__.py
migrations/tenant/versions/*.py
!migrations/tenant/versions/__init__.py

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log

# Backup files
*.backup
*.sql
backups/