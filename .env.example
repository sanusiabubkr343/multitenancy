# Database
MASTER_DATABASE_URL=postgresql://postgres:password@localhost:5432/master_db

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin
ADMIN_EMAIL=admin@saas.com
ADMIN_PASSWORD=changeme

# Tenant Database Template (same server as master, different databases)
TENANT_DB_URL_TEMPLATE=postgresql://postgres:password@localhost:5432/{tenant_name}_db
TENANT_DB_INTERNAL_URL_TEMPLATE=postgresql://postgres:password@postgres:5432/{tenant_name}_db

# Environment
ENVIRONMENT=development
DEBUG=true
